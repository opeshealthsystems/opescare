{
    "name": "opescare/sdk",
    "description": "Official OpesCare Connect Suite PHP SDK — Health ID, Patients, Consents, Records, Webhooks",
    "type": "library",
    "license": "MIT",
    "keywords": ["opescare", "healthcare", "health-id", "fhir", "interoperability"],
    "homepage": "https://opescare.com/developers",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.8",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/psr7": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "OpesCare\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpesCare\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "minimum-stability": "stable"
}
