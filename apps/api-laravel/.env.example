APP_NAME="OpesCare"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
CORS_ALLOWED_ORIGINS=https://opescare.cloud,https://www.opescare.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=production_stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=90
EXTERNAL_LOG_CHANNEL=datadog
DATADOG_HOST=intake.logs.datadoghq.eu
DATADOG_PORT=10518
PAPERTRAIL_HOST=
PAPERTRAIL_PORT=

DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=opescare
# DB_USERNAME=root
# DB_PASSWORD=
DB_READ_HOST_1=
DB_READ_HOST_2=
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=opescare-backups
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OpesCare Demo Mode Settings
OPESCARE_DEMO_MODE=false
OPESCARE_PUBLIC_DEMO_MODE=true
OPESCARE_INTERNAL_DEMO_MODE=true
OPESCARE_DEMO_EXTERNAL_SERVICES_SIMULATED=true
DEMO_ALLOWED_IPS=

# Laravel Horizon
HORIZON_ADMIN_EMAILS=
HORIZON_MEMORY_LIMIT=256
HORIZON_SUPERVISOR_TIMEOUT=60

# Automated Encrypted Backups (spatie/laravel-backup)
BACKUP_ENCRYPTION_PASSWORD=
BACKUP_ALERT_EMAIL=devops@opescare.com

# ── KMS / HSM encryption ─────────────────────────────────────────────────────
KMS_DRIVER=local
KMS_AWS_KEY_ID=
KMS_AWS_REGION=eu-west-1

# --- WHATSAPP BUSINESS API ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v18.0

# --- FCM / APNS PUSH NOTIFICATIONS ---
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVER_KEY=

# --- MOBILE MONEY (MTN MoMo) ---
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_KEY=
MTN_MOMO_USER_ID=
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=XAF
MTN_MOMO_CALLBACK_URL=
MTN_MOMO_CALLBACK_SECRET=

# --- MOBILE MONEY (Orange Money) ---
ORANGE_MONEY_BASE_URL=https://api.orange.com
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CURRENCY=XAF
ORANGE_MONEY_RETURN_URL=
ORANGE_MONEY_CANCEL_URL=
ORANGE_MONEY_NOTIF_URL=
ORANGE_MONEY_CALLBACK_SECRET=

# --- MFA / TWO-FACTOR (staff/admin TOTP — scaffold; enforcement not yet wired) ---
MFA_ISSUER=OpesCare
MFA_REQUIRED_ROLES=super_admin,admin

# --- AUDIT ARCHIVE (immutable cold storage) ---
# Disk that audit archives are written to. In production set to an S3 bucket with
# Object Lock (WORM) + versioning so 7-year audit records cannot be altered/deleted.
AUDIT_ARCHIVE_DISK=local
AUDIT_RETENTION_MONTHS=12

# --- MOBILE APP VERSION GATE (GET /api/mobile/app-config) ---
# Drives the patient app's forced-update flow. Bump these to push users off an
# old/insecure build without a code deploy. Build number is pubspec `version: x.y.z+BUILD`.
MOBILE_MIN_SUPPORTED_BUILD=1
MOBILE_LATEST_VERSION=1.0.0
MOBILE_STORE_URL=https://play.google.com/store/apps/details?id=com.opescare.patient

# --- DHIS2 (MINSANTE Cameroon) ---
DHIS2_BASE_URL=
DHIS2_USERNAME=
DHIS2_PASSWORD=
DHIS2_ORG_UNIT=
DHIS2_DATASET_ID=
DHIS2_ENABLED=false
# Data Element UIDs — obtain from DHIS2: Maintenance → Data Elements
# Leave blank to exclude that element from the monthly push payload.
DHIS2_DE_OPD_TOTAL=
DHIS2_DE_OPD_MALE=
DHIS2_DE_OPD_FEMALE=
DHIS2_DE_OPD_UNDER5=
DHIS2_DE_OPD_REFERRALS_IN=
DHIS2_DE_OPD_REFERRALS_OUT=
DHIS2_DE_MALARIA_CONFIRMED=
DHIS2_DE_MALARIA_PRESUMED=
DHIS2_DE_MALARIA_TREATED=
DHIS2_DE_HIV_TESTED=
DHIS2_DE_HIV_POSITIVE=
DHIS2_DE_TB_PRESUMPTIVE=
DHIS2_DE_TB_CONFIRMED=
DHIS2_DE_TB_STARTED_TREATMENT=
DHIS2_DE_HYPERTENSION_NEW=
DHIS2_DE_HYPERTENSION_FOLLOWUP=
DHIS2_DE_DIABETES_NEW=
DHIS2_DE_DIABETES_FOLLOWUP=
DHIS2_DE_MATERNAL_VISITS=
DHIS2_DE_ANC_FIRST_VISITS=
DHIS2_DE_DELIVERIES_TOTAL=
DHIS2_DE_DELIVERIES_SKILLED=
DHIS2_DE_POSTNATAL_VISITS=
DHIS2_DE_IMMUNIZATIONS=
DHIS2_DE_BCG_DOSES=
DHIS2_DE_PENTA3_DOSES=
DHIS2_DE_MEASLES_DOSES=
DHIS2_DE_LAB_TESTS_TOTAL=
DHIS2_DE_LAB_MALARIA_RDT=
DHIS2_DE_PRESCRIPTIONS_TOTAL=

# --- HL7 ADT ---
HL7_HOST=
HL7_PORT=2575
HL7_FACILITY_ID=
HL7_SENDING_APP=OpesCare

# --- CDN ---
CDN_URL=
CDN_BUCKET=
CDN_ENDPOINT=

# --- USSD (Africa's Talking) ---
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_USSD_CODE=
AFRICASTALKING_USSD_CALLBACK_SECRET=

# --- PHARMACY ROUTING ---
PHARMACY_ROUTING_WEBHOOK_URL=

# --- DATA RETENTION (days) ---
RETENTION_AUDIT_LOGS_DAYS=2555
RETENTION_ACCESS_LOGS_DAYS=365
RETENTION_API_USAGE_LOGS_DAYS=180
RETENTION_USSD_SESSIONS_DAYS=30
RETENTION_EXPORT_FILES_HOURS=24

# --- APP REGION ---
APP_REGION=af-south-1
APP_FALLBACK_REGION=

# --- SNYK SECURITY SCANNING ---
# Set in GitHub Actions secrets, not locally (Settings → Secrets → SNYK_TOKEN)
SNYK_TOKEN=
